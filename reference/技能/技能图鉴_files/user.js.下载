    /**
     * 安全地重写localStorage方法，避免与其他模块冲突
     * 如果方法已被重写，则使用事件监听器
     */
    // 使用独立的标记对象来避免污染localStorage
    const localStorageOverrideFlags = {
        setItemOverridden: false,
        removeItemOverridden: false
    };

    /**
     * 设置用户localStorage监听器
     * 只监听包含'_'且值为'1'或''的键的变化，避免不必要的触发
     * 使用独立标记避免localStorage污染
     */
    function setupUserLocalStorageListener() {
        if (localStorageOverrideFlags.setItemOverridden) {
            // 如果localStorage已被其他模块重写，使用事件监听
            document.addEventListener('localStorageChange', function(e) {
                if (e.detail && e.detail.key && e.detail.key.includes('_') && 
                    (e.detail.action === 'setItem' || e.detail.action === 'removeItem')) {
                    // 只处理包含'_'且值为'1'或''的键
                    if (e.detail.action === 'setItem' && (e.detail.value === '1' || e.detail.value === '')) {
                        handleLocalStorageChange();
                    } else if (e.detail.action === 'removeItem') {
                        handleLocalStorageChange();
                    }
                }
            });
        } else {
            // 如果localStorage未被重写，进行重写
            localStorage.setItem = function (key, value) {
                const result = originalSetItem.apply(this, arguments);
                // 只对包含'_'且值为'1'或''的键触发处理
                if (key && key.includes('_') && (value === '1' || value === '')) {
                    handleLocalStorageChange();
                }
                // 触发自定义事件，通知其他模块
                document.dispatchEvent(new CustomEvent('localStorageChange', {
                    detail: { key: key, value: value, action: 'setItem' }
                }));
                return result;
            };
            localStorageOverrideFlags.setItemOverridden = true;

            localStorage.removeItem = function (key) {
                const result = originalRemoveItem.apply(this, arguments);
                // 只对包含'_'的键触发处理
                if (key && key.includes('_')) {
                    handleLocalStorageChange();
                }
                // 触发自定义事件，通知其他模块
                document.dispatchEvent(new CustomEvent('localStorageChange', {
                    detail: { key: key, action: 'removeItem' }
                }));
                return result;
            };
            localStorageOverrideFlags.removeItemOverridden = true;
        }
    }

    /**
