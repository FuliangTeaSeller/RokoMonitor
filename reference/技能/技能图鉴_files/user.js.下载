            const xhr = new XMLHttpRequest();
            xhr.open('POST','saveData.php', true);
            xhr.setRequestHeader('Content-Type', 'application/json');
            xhr.onreadystatechange = function () {
                if (xhr.readyState === 4 && xhr.status === 200) {
                    //console.log('数据已成功保存到数据库');
                }
            };
            xhr.send(JSON.stringify(dataToSend));
            previousFilteredData = currentFilteredData;
        }
    }

    /**
     * 清理localStorage中的污染数据
     * 移除函数代码、对象和其他非预期内容
     */
    function cleanLocalStoragePollution() {
        const keysToRemove = [];
        
        for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            const value = localStorage.getItem(key);
            
            // 检查是否为污染数据
            if (value && typeof value === 'string') {
                // 移除包含函数代码的项
                if (value.startsWith('function') || 
                    value.includes('_isOverridden') ||
                    value.startsWith('[object') ||
                    value.includes('apply(this, arguments)') ||
                    value.includes('addEventListener') ||
                    value.includes('dispatchEvent')) {
                    keysToRemove.push(key);
                }
            }
        }
        
        // 移除污染的键值对
        keysToRemove.forEach(key => {
            console.warn('清理localStorage污染数据:', key);
            originalRemoveItem.call(localStorage, key);
        });
        
        if (keysToRemove.length > 0) {
            //console.log('已清理', keysToRemove.length, '个localStorage污染项');
        }
    }

