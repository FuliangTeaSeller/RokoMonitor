                            }
                            resolve(false); // 选择云端数据
                        };
                        
                        // 设置多种事件处理方式以确保iOS兼容性
                        localButton.onclick = handleLocalChoice;
                        localButton.addEventListener('click', handleLocalChoice);
                        localButton.addEventListener('touchend', handleLocalChoice);
                        
                        cloudButton.onclick = handleCloudChoice;
                        cloudButton.addEventListener('click', handleCloudChoice);
                        cloudButton.addEventListener('touchend', handleCloudChoice);
                    }).then(choice => {
                        if (choice) {
                            // 发送请求到后端用本地覆盖数据库存档， updateArchive.php 的后端脚本处理更新逻辑
                            updateArchiveInBackend(username, JSON.stringify(localStorageData));
                        } else {
                            // 清空本地存档，为覆盖做准备
                            const keysToClear = [];
                            for (let i = 0; i < localStorage.length; i++) {
                                const key = localStorage.key(i);
                                // 保留 loggedInUser、userOpenid 和 userPhone，其他存档相关数据清除
                                if (key !== 'loggedInUser' && key !== 'userOpenid' && key !== 'userPhone') {
                                    keysToClear.push(key);
                                }
                            }
                            // 暂时恢复原始的 removeItem 方法，避免重复触发 saveData.php
                            const originalRemoveItemFunc = localStorage.removeItem;
                            localStorage.removeItem = originalRemoveItem;
                            keysToClear.forEach(key => {
                                localStorage.removeItem(key); // 使用原始的 removeItem
                            });
                            // 恢复重写的 removeItem 方法
                            localStorage.removeItem = originalRemoveItemFunc;

                            // 用数据库存档覆盖本地 localStorage
                            // 暂时恢复原始的 setItem 方法，避免重复触发 saveData.php
                            const originalSetItemFunc = localStorage.setItem;
                            localStorage.setItem = originalSetItem;

                            for (const key in userArchiveData) {
                                localStorage.setItem(key, userArchiveData[key]); // 使用原始的 setItem
                            }

                            // 恢复重写的 setItem 方法
                            localStorage.setItem = originalSetItemFunc;

                            // 可根据需要刷新页面相关显示等
                            InitMarkerLayer();
                            freshMarkerLayer();
                            
                            // 手动触发数量统计更新（因为使用了原始localStorage方法绕过了监听器）
                            if (typeof updateCompletedCounts === 'function') {
                                setTimeout(updateCompletedCounts, 200);
                            }

                            // 更新 previousFilteredData 以反映本地数据已与云端同步
                            previousFilteredData = getFilteredLocalStorageData();
                        }
                    });
                }
            }
        };
        const data = {
            username: username
        };
        xhr.send(JSON.stringify(data));
    }
    
    /**
     * 获取过滤后的localStorage数据用于比较
     * 排除系统保留键和函数属性，防止localStorage污染
     */
    function getFilteredLocalStorageDataForComparison() {
        const filteredData = {};
        for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            const value = localStorage.getItem(key);
            
            // 排除系统保留键
            if (key === 'layerNumber' || 
                key === 'loggedInUser' || 
                key === 'NetSync' || 
                key === 'userOpenid' || 
                key === 'userPhone') {
                continue;
            }
            
            // 排除函数和对象类型的值，防止localStorage污染
            if (typeof value === 'string' && 
                !value.startsWith('function') && 
                !value.startsWith('[object') && 
                !value.includes('_isOverridden') &&
                value !== 'undefined' &&
                value !== 'null') {
                filteredData[key] = value;
            }
        }
        return filteredData;
    }
    
    function isDataDifferent(localData, archiveData) {
        const localKeys = Object.keys(localData);
        const archiveKeys = Object.keys(archiveData);
        if (localKeys.length!== archiveKeys.length) {
            return true;
        }
        for (const key of localKeys) {
            if (localData[key]!== archiveData[key]) {
                return true;
            }
        }
        return false;
    }

