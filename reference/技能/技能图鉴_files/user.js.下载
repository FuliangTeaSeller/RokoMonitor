    // 防重复触发的事件处理器包装函数
    function createDebounceHandler(handler, delay = 300) {
        let timeoutId = null;
        let isProcessing = false;
        
        return function(event) {
            // 如果正在处理中，直接返回
            if (isProcessing) {
                if (event && event.preventDefault) {
                    event.preventDefault();
                }
                return;
            }
            
            // 清除之前的定时器
            if (timeoutId) {
                clearTimeout(timeoutId);
            }
            
            // 设置处理标志
            isProcessing = true;
            
            // 执行处理函数
            handler.call(this, event);
            
            // 延迟重置处理标志
            timeoutId = setTimeout(() => {
                isProcessing = false;
                timeoutId = null;
            }, delay);
        };
    }
    
    // 使用防重复触发机制绑定退出登录事件
    const debouncedLogout = createDebounceHandler(handleLogout);
